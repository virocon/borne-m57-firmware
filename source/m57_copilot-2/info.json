{
    "keyboard_name": "BCORNE", 
    "maintainer": "MT",
    "manufacturer": "DH747",
    "bootloader": "custom",
    "url": "https://github.com/foostan/crkbd",
    "usb": {
        "pid": "0x45D4",
        "vid": "0x6401",
        "device_version": "0.0.1"
    },
    "processor": "STM32F401",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "nkro": true,
        "oled": false,
        "rgblight": false,
        "rgb_matrix": true,
        "mousekey": true,
        "encoder": true
    },
    "encoder": {
        "rotary": [
            {"pin_a": "B8", "pin_b": "B9", "resolution": 2}
        ]
    },
        "split": {
        "enabled": true,
        "encoder": {
            "right": {
                "rotary": [
                    {"pin_a": "B4", "pin_b": "B6", "resolution": 2}
                ]
            }
        }
         },
         "transport": {
            "protocol": "serial_usart",
            "sync": {
                "matrix_state": true
            },
            "watchdog": true
         },
